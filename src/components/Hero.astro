---
import { content, LINKS } from '../i18n/content.js';
import { getLatestRelease } from '../lib/release.js';

const t = content.es;
const release = await getLatestRelease();
---

<section id="top" class="hero wrap">
  <span class="eyebrow hero-eyebrow" data-i18n="hero.eyebrow">{t.hero.eyebrow}</span>

  <h1 class="hero-title" data-i18n="hero.title">{t.hero.title}</h1>

  <p class="hero-brandline">
    &ldquo;<span data-i18n="hero.brandLine">{t.hero.brandLine}</span>&rdquo;
  </p>

  <div class="hero-ctas">
    <a href={LINKS.exeLatest} class="btn btn-primary">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v13"/><path d="m6 11 6 6 6-6"/><path d="M5 21h14"/></svg>
      <span data-i18n="hero.primaryCta">{t.hero.primaryCta}</span>
    </a>
    <a href={LINKS.releases} class="btn btn-secondary">
      <span data-i18n="hero.secondaryCta">{t.hero.secondaryCta}</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
    </a>
  </div>

  <div class="hero-meta">
    {release.version && (
      <>
        <span><span data-i18n="hero.metaVersion">{t.hero.metaVersion}</span> {release.version}</span>
        <span class="dot">·</span>
      </>
    )}
    {release.sizeLabel && (
      <>
        <span>{release.sizeLabel}</span>
        <span class="dot">·</span>
      </>
    )}
    <a href={LINKS.sha256} class="link" data-i18n="hero.metaSha">{t.hero.metaSha}</a>
  </div>

  <p class="hero-smartscreen">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
    <span data-i18n="hero.smartscreen">{t.hero.smartscreen}</span>
  </p>
</section>

<style>
  .hero {
    padding: clamp(56px, 10vw, 112px) 24px 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    animation: hero-fade-up 0.6s var(--ease-out) both;
  }

  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-eyebrow {
    color: var(--brand-300);
  }

  .hero-title {
    font-size: clamp(34px, 5.4vw, 58px);
    font-weight: 650;
    letter-spacing: var(--tracking-tight);
    line-height: 1.12;
    max-width: 780px;
    color: var(--fg-1);
    margin: 0;
  }

  .hero-brandline {
    font-family: var(--font-mono);
    font-size: clamp(14px, 1.6vw, 17px);
    color: var(--fg-2);
    background: var(--glass-2);
    border: 1px solid var(--hairline);
    border-radius: var(--r-md);
    padding: 10px 18px;
    margin: 0;
    max-width: 640px;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-top: 8px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px 10px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--fg-3);
  }

  .hero-meta .dot {
    color: var(--fg-4);
  }

  .hero-smartscreen {
    max-width: 560px;
    font-size: 12.5px;
    color: var(--fg-3);
    margin: 4px 0 0;
    line-height: var(--lh-normal);
  }

  .hero-smartscreen svg {
    display: inline;
    vertical-align: -2px;
    margin-right: 4px;
  }
</style>
