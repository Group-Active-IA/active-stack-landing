---
import { content, LINKS } from '../i18n/content.js';
const t = content.es;
---

<header class="site-header">
  <div class="wrap header-bar">
    <a href="#top" class="brand">
      <span class="brand-dot"></span>
      <span class="brand-name">active-stack</span>
    </a>

    <input type="checkbox" id="nav-toggle" class="sr-only nav-toggle-input" aria-hidden="true" />

    <nav class="site-nav" aria-label="Main">
      <a href="#descargar" data-i18n="nav.download">{t.nav.download}</a>
      <a href="#que-es" data-i18n="nav.whatIs">{t.nav.whatIs}</a>
      <a href="#opsx" data-i18n="nav.opsx">{t.nav.opsx}</a>
      <a href="#catalogo" data-i18n="nav.catalog">{t.nav.catalog}</a>
      <a href="#faq" data-i18n="nav.faq">{t.nav.faq}</a>
    </nav>

    <div class="header-actions">
      <button type="button" id="lang-toggle" class="pill-btn" data-i18n-title="nav.langToggle" title={t.nav.langToggle}>
        <span class="lang-es" data-lang-mark="es">ES</span>
        <span class="lang-sep">/</span>
        <span class="lang-en" data-lang-mark="en">EN</span>
      </button>

      <button type="button" id="theme-toggle" class="icon-btn" data-i18n-title="nav.themeToggle" title={t.nav.themeToggle} aria-label="theme">
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"/></svg>
        <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      </button>

      <a href={LINKS.repo} target="_blank" rel="noopener" class="icon-btn" data-i18n-title="nav.github" title={t.nav.github}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.5 0 12.3c0 5.44 3.44 10.05 8.21 11.68.6.12.82-.27.82-.6 0-.3-.01-1.08-.02-2.12-3.34.75-4.04-1.66-4.04-1.66-.55-1.44-1.34-1.83-1.34-1.83-1.09-.77.08-.75.08-.75 1.2.09 1.84 1.26 1.84 1.26 1.07 1.87 2.81 1.33 3.5 1.02.11-.79.42-1.33.76-1.64-2.67-.31-5.47-1.38-5.47-6.14 0-1.36.47-2.46 1.24-3.33-.12-.31-.54-1.57.12-3.28 0 0 1.01-.33 3.3 1.27a11.2 11.2 0 0 1 6.01 0c2.29-1.6 3.3-1.27 3.3-1.27.66 1.71.24 2.97.12 3.28.77.87 1.24 1.97 1.24 3.33 0 4.77-2.81 5.82-5.49 6.13.43.38.81 1.13.81 2.28 0 1.65-.02 2.98-.02 3.38 0 .33.21.72.83.6C20.57 22.34 24 17.74 24 12.3 24 5.5 18.63 0 12 0Z"/></svg>
      </a>

      <label for="nav-toggle" class="icon-btn nav-toggle-btn" aria-label="menu">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </label>
    </div>
  </div>

  <div class="mobile-nav">
    <a href="#descargar" data-i18n="nav.download">{t.nav.download}</a>
    <a href="#que-es" data-i18n="nav.whatIs">{t.nav.whatIs}</a>
    <a href="#opsx" data-i18n="nav.opsx">{t.nav.opsx}</a>
    <a href="#catalogo" data-i18n="nav.catalog">{t.nav.catalog}</a>
    <a href="#faq" data-i18n="nav.faq">{t.nav.faq}</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--glass-1);
    backdrop-filter: blur(var(--blur-md)) saturate(140%);
    -webkit-backdrop-filter: blur(var(--blur-md)) saturate(140%);
    border-bottom: 1px solid var(--hairline);
  }

  .header-bar {
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--fg-1);
  }

  .brand-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--brand);
    box-shadow: 0 0 12px var(--brand-glow);
  }

  .brand-name {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: var(--tracking-snug);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .site-nav a {
    font-size: 14px;
    color: var(--fg-2);
    text-decoration: none;
  }

  .site-nav a:hover {
    color: var(--fg-1);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pill-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 34px;
    padding: 0 12px;
    border-radius: var(--r-pill);
    background: var(--glass-2);
    border: 1px solid var(--hairline);
    color: var(--fg-2);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
  }

  .lang-sep {
    color: var(--fg-4);
  }

  .lang-es,
  .lang-en {
    color: var(--fg-4);
    transition: color var(--dur-fast) var(--ease-out);
  }

  html[lang='es'] .lang-es,
  html[lang='en'] .lang-en {
    color: var(--brand-300);
  }

  .icon-btn {
    width: 34px;
    height: 34px;
    border-radius: var(--r-pill);
    background: var(--glass-2);
    border: 1px solid var(--hairline);
    color: var(--fg-2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .icon-sun {
    display: none;
  }
  html[data-theme='light'] .icon-sun {
    display: block;
  }
  html[data-theme='light'] .icon-moon {
    display: none;
  }

  .nav-toggle-btn {
    display: none;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px 24px 20px;
    gap: 4px;
    border-top: 1px solid var(--hairline);
  }

  .mobile-nav a {
    padding: 10px 4px;
    font-size: 15px;
    color: var(--fg-2);
    text-decoration: none;
  }

  .nav-toggle-input:checked ~ .mobile-nav {
    display: flex;
  }

  @media (max-width: 760px) {
    .site-nav {
      display: none;
    }
    .nav-toggle-btn {
      display: flex;
    }
  }

  @media (min-width: 761px) {
    .mobile-nav {
      display: none !important;
    }
  }
</style>
