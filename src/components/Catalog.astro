---
import { content } from '../i18n/content.js';
const t = content.es;
const typeColors = {
  skill: { bg: 'var(--as-violet-soft)', color: 'var(--as-violet)' },
  config: { bg: 'var(--as-cyan-soft)', color: 'var(--as-cyan)' },
  external: { bg: 'var(--as-teal-soft)', color: 'var(--as-teal)' },
};
---

<section id="catalogo" class="wrap section">
  <div class="section-head">
    <span class="eyebrow" style="color: var(--as-teal);" data-i18n="catalog.eyebrow">{t.catalog.eyebrow}</span>
    <h2 class="section-title" data-i18n="catalog.title">{t.catalog.title}</h2>
    <p class="section-sub" data-i18n="catalog.subtitle">{t.catalog.subtitle}</p>
  </div>

  <div class="catalog-grid">
    {t.catalog.items.map((item, i) => {
      const c = typeColors[item.type];
      return (
        <div class="glass-card catalog-card">
          <div class="catalog-card-head">
            <span class="catalog-name">{item.name}</span>
            <span class="catalog-type" style={`background:${c.bg}; color:${c.color}`}>{item.type}</span>
          </div>
          <p data-i18n={`catalog.items.${i}.desc`}>{item.desc}</p>
        </div>
      );
    })}
  </div>
</section>

<style>
  .section-sub {
    margin: 6px 0 0;
    font-size: 15px;
    color: var(--fg-3);
  }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
  }

  .catalog-card {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .catalog-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .catalog-name {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 600;
    color: var(--fg-1);
  }

  .catalog-type {
    font-size: 10.5px;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--r-pill);
  }

  .catalog-card p {
    margin: 0;
    font-size: 13.5px;
    color: var(--fg-3);
    line-height: var(--lh-normal);
  }
</style>
